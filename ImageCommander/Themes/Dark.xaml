<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Mark as theme dictionary -->
  <!-- Brushes -->
  <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#171717"/>
  <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="ControlTextBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="PanelBrush" Color="#252525"/>
  <SolidColorBrush x:Key="BorderBrushLight" Color="#3A3A3A"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#0078D7"/>

  <!-- System color keys for built-in templates -->
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#171717"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InfoBrushKey}" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InfoTextBrushKey}" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>

  <!-- Basic control styles -->
  <Style TargetType="Button">
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
  </Style>

  <Style TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
  </Style>

  <Style TargetType="ComboBox">
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
  </Style>

  <Style TargetType="Label">
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
  </Style>

  <Style TargetType="ListView">
    <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
  </Style>

  <Style TargetType="ListViewItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="GridViewColumnHeader">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
  </Style>

  <Style TargetType="Menu">
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
  </Style>

  <!-- Ensure submenu panels (Popup) use theme brushes -->
  <Style TargetType="ContextMenu">
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
  </Style>

  <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
  </Style>

  <!-- Generic control style to ensure backgrounds/foregrounds are applied -->
  <Style TargetType="Control">
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}"/>
  </Style>

  <Style TargetType="ScrollViewer">
    <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
  </Style>

</ResourceDictionary>
<Window x:Class="ImageCommander.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen" Height="300" Width="650" MinWidth="650" MaxWidth="650" MinHeight="300" MaxHeight="300" WindowStartupLocation="CenterOwner"
        Icon="{StaticResource AppIcon}"
        Background="WhiteSmoke" Foreground="Black">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,6">
            <Label Content="Standard Quellordner:" VerticalAlignment="Center"/>
            <TextBox x:Name="tbDefaultSource" Width="300" Margin="6,0,0,0" />
            <Button Content="Durchsuchen" Click="BrowseSource_Click" Margin="6,0,0,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,6">
            <Label Content="Standard Zielordner:" VerticalAlignment="Center"/>
            <TextBox x:Name="tbDefaultDestination" Width="300" Margin="6,0,0,0"/>
            <Button Content="Durchsuchen" Click="BrowseDestination_Click" Margin="6,0,0,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,6">
            <Label Content="Wasserzeichen aktiv:" VerticalAlignment="Center"/>
            <CheckBox x:Name="chkWatermarkEnabled" Margin="6,0,0,0" VerticalAlignment="Center"/>
            <Label Content="Wasserzeichen-Datei:" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <TextBox x:Name="tbWatermarkFile" Width="200" Margin="6,0,0,0"/>
            <Button Content="Durchsuchen" Click="BrowseWatermark_Click" Margin="6,0,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Entwickler: IT-Solution Rath" TextWrapping="Wrap" VerticalAlignment="Bottom"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="90" Click="Ok_Click" Margin="0,0,6,0"/>
            <Button Content="Abbrechen" Width="90" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
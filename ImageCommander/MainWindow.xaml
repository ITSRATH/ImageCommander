<Window x:Class="ImageCommander.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageCommander"
        mc:Ignorable="d"
        Title="Image Commander" Height="520" Width="950" MinWidth="950" MinHeight="520"
        Icon="{StaticResource AppIcon}"
        FontFamily="Segoe UI" Background="WhiteSmoke">

    <Window.Resources>
        <!-- Colors and brushes -->
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D7"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F7F9FB"/>
        <SolidColorBrush x:Key="BorderBrushLight" Color="#E0E6ED"/>

        <!-- Common spacings -->
        <Thickness x:Key="OuterPadding">10</Thickness>
        <Thickness x:Key="ControlSpacing">6,4</Thickness>

        <!-- Simple control styles to make UI consistent -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="MinWidth" Value="160"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu bar -->
        <Menu Grid.Row="0" Background="Transparent">
            <MenuItem Header="_Menü">
                <MenuItem Header="_Einstellungen" Click="MenuSettings_Click"/>
                <Separator/>
                <MenuItem Header="_Verlassen" Click="MenuExit_Click"/>
            </MenuItem>
        </Menu>

        <!-- Settings panel -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="6" BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="1" Padding="8" Margin="0,8,0,8">
            <!-- Use Grid to avoid clipping when window is narrow and to keep controls aligned -->
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Label Content="Konvertiere zu:" VerticalAlignment="Center"/>
                    <ComboBox SelectedIndex="0" x:Name="TypeConvertionTo" VerticalAlignment="Center">
                        <ComboBoxItem Content="JPG"/>
                        <ComboBoxItem Content="PNG"/>
                        <ComboBoxItem Content="BMP"/>
                        <ComboBoxItem Content="TIFF"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Vertical" Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Label Content="Bildqualität:" VerticalAlignment="Center"/>
                        <ComboBox SelectedIndex="0" x:Name="qualitySelection" VerticalAlignment="Center">
                            <ComboBoxItem Content="100% (Original)"/>
                            <ComboBoxItem Content="75%"/>
                            <ComboBoxItem Content="50%"/>
                            <ComboBoxItem Content="25%"/>
                        </ComboBox>
                    </StackPanel>
                    <!-- Mail-Accept: only compress images larger than selected threshold -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Label Content="Mail-Accept:" VerticalAlignment="Center" ToolTip="Nur Bilder über der gewählten Größe komprimieren"/>
                        <ComboBox SelectedIndex="0" x:Name="mailAcceptSizeSelection" VerticalAlignment="Center" ToolTip="Wähle maximale Dateigröße für Mail-Accept">
                            <ComboBoxItem Content="Nein"/>
                            <ComboBoxItem Content="25 MB"/>
                            <ComboBoxItem Content="10 MB"/>
                            <ComboBoxItem Content="5 MB"/>
                            <ComboBoxItem Content="3 MB"/>
                            <ComboBoxItem Content="1 MB"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Label Content="Umbenennen:" VerticalAlignment="Center"/>
                        <RadioButton Content="Ja" GroupName="setRename" x:Name="renameActive" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        <RadioButton Content="Nein" GroupName="setRename" IsChecked="True" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="renameText" Width="180" Margin="8,0,8,0" VerticalAlignment="Center"/>
                </StackPanel>
                

                <!-- spacer in column 3 -> pushes meta controls to the right without clipping -->
                <StackPanel Orientation="Vertical" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Label Content="Metadaten entfernen:" VerticalAlignment="Center"/>
                        <RadioButton Content="Ja" GroupName="setRemoveMeta" x:Name="removeMetadata" VerticalAlignment="Center"/>
                        <RadioButton Content="Nein" GroupName="setRemoveMeta" IsChecked="True" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Label Content="Ergebniss in zip packen:" VerticalAlignment="Center"/>
                        <CheckBox x:Name="zipAfterConvert" VerticalAlignment="Center" ToolTip="Alle konvertierten Dateien in eine ZIP-Datei packen"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Source/Destination and file list -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="White" BorderBrush="{StaticResource BorderBrushLight}" BorderThickness="1" CornerRadius="6" Padding="8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Content="Quellordner:"/>
                    <TextBox x:Name="sourceFolderPath" Width="260"/>
                    <Button Content="Durchsuchen" Click="BrowseSourceFolder_Click"/>

                    <Label Content="Zielordner:" Margin="12,0,12,0"/>
                    <TextBox x:Name="destinationFolderPath" Width="260"/>
                    <Button Content="Durchsuchen" Click="BrowseDestinationFolder_Click"/>
                </StackPanel>
            </Border>

            <ListView x:Name="lvFiles" Grid.Row="1" Margin="0,10,0,0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="Auto" Header="Auswahl">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Dateiname" Width="Auto" DisplayMemberBinding="{Binding FileName}"/>
                        <GridViewColumn Header="Typ" Width="80" DisplayMemberBinding="{Binding FileType}"/>
                        <GridViewColumn Header="Datum" Width="120" DisplayMemberBinding="{Binding FileDate}"/>
                        <GridViewColumn Header="Größe" Width="120" DisplayMemberBinding="{Binding FileSize}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- Footer: selection, progress and start -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox Content="Alle auswählen" x:Name="selectAllCheckBox" VerticalAlignment="Center" Checked="selectAllCheckBox_Checked" Unchecked="selectAllCheckBox_Unchecked"/>

            <Grid Grid.Column="1" Margin="12,0" VerticalAlignment="Center" >
                <ProgressBar x:Name="statusProgressBar" Minimum="0" Maximum="100" Value="0" Height="25"/>
                <TextBlock x:Name="statusText" Text="Bereit"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Black" IsHitTestVisible="False" />
            </Grid>

            <Button Grid.Column="2" Content="Start" x:Name="startButton" Width="90" Click="startButton_Click" HorizontalAlignment="Right"/>
        </Grid>

    </Grid>
</Window>
